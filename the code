import json, os
from datetime import datetime, timedelta
DB_FILE = "inventory.json"
def load():
   if os.path.exists(DB_FILE):
       with open(DB_FILE) as f:
           return json.load(f)
   return {"items": {}, "transactions": []}


def save(db):
   with open(DB_FILE, "w") as f:
       json.dump(db, f, indent=2)


def today():
   return datetime.now().strftime("%Y-%m-%d")


def now_time():
   return datetime.now().strftime("%H:%M")


def rp(n):
   return f"Rp {int(n):,}".replace(",", ".")


def line(w=56):
   print("─" * w)


def clear():
   os.system("cls" if os.name == "nt" else "clear")
#sell


def sell(db):
   clear()
   print("SELL / USE ITEM\n")


   if not db["items"]:
       print("No items in inventory. Add items first.")
       input("\nEnter to continue...")
       return


   name = input("Item name: ").strip()
   item = db["items"].get(name)
   if not item:
       print(f"  '{name}' not found.")
       input("\nEnter to continue...")
       return
   print(f"  Stock: {item['qty']}  |  Cost: {rp(item['cost'])}  |  Sell: {rp(item['sell'])}")
   try:
       qty = int(input("Qty [1]: ") or "1")
       price_in = input(f"Sale price/unit [{rp(item['sell'])}]: ").strip()
       price = float(price_in) if price_in else item["sell"]
   except ValueError:
       print("  Invalid input.")
       input("\nEnter to continue...")
       return
   if item["qty"] < 1:
       print(f"  Only {item['qty']} in stock.")
       input("\nEnter to continue...")
       return
   profit = (price - item["cost"]) * qty
   margin = (profit / (price * qty) * 100) if price > 0 else 0
   print(f"\n  Revenue : {rp(price * qty)}")
   print(f"  Profit  : {rp(profit)}")
   print(f"  Margin  : {margin:.1f}%")
   if input("\nConfirm? [Y/n]: ").strip().lower() in ("n", "no"):
       return
   item["qty"] -= qty
   db["transactions"].append({
       "date": today(), "time": now_time(),
       "item": name, "qty": qty,
       "sell_price": price, "cost": item["cost"], "profit": profit
   })
   save(db)
   print(f"  Done — {qty} x {name} recorded.")
   input("\nEnter to continue...")
#storage
def show_stock(db):
   clear()
   print("STORAGE LIST\n")
   items = db["items"]
   if not items:
       print("  No items.")
       input("\nEnter to continue...")
       return
   q = input("Search (blank = all): ").strip().lower()
   found = {k: v for k, v in items.items() if not q or q in k.lower()}
   print()
   print(f"  {'ITEM':<28} {'QTY':>5}  {'COST':>12}  {'SELL':>12}  STATUS")
   line()
   for name, it in sorted(found.items()):
       if it["qty"] == 0:
           status = "OUT"
       elif it["qty"] <= it.get("alert", 5):
           status = "LOW"
       else:
           status = "ok"
       print(f"  {name:<28} {it['qty']:>5}  {rp(it['cost']):>12}  {rp(it['sell']):>12}  {status}")
   line()
   print(f"  {len(found)} items")
   input("\nEnter to continue...")
#sales log
def show_log(db):
   clear() #transactions
   print("TODAY'S SALES LOG\n")
   txs = [t for t in db["transactions"] if t["date"] == today()]
   if not txs:
       print("  No sales today.")
       input("\nEnter to continue...")
       return
   print(f"  {'TIME':<6}  {'ITEM':<26}  {'QTY':>4}  {'REVENUE':>12}  {'PROFIT':>12}  {'MARGIN':>7}")
   line(76)
   for t in reversed(txs):
       rev = t["sell_price"] * t["qty"]
       m = (t["profit"] / rev * 100) if rev > 0 else 0
       print(f"  {t['time']:<6}  {t['item']:<26}  {t['qty']:>4}  {rp(rev):>12}  {rp(t['profit']):>12}  {m:>6.1f}%")
   line(76)


   total_rev = sum(t["sell_price"] * t["qty"] for t in txs) #total profit, revenue, and margin in %
   total_profit = sum(t["profit"] for t in txs)
   total_margin = (total_profit / total_rev * 100) if total_rev > 0 else 0
   print(f"  {'TOTAL':<34}  {rp(total_rev):>12}  {rp(total_profit):>12}  {total_margin:>6.1f}%")
   input("\nEnter to continue...")
