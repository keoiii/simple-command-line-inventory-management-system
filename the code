#Add / restock
def add_item(db):
   clear()
   print("ADD / RESTOCK ITEM\n")
   name = input("Item name: ").strip()
   if not name:#check for existing items
       return
   existing = db["items"].get(name)
   if existing:
       print(f"  '{name}' exists. Stock: {existing['qty']}")
       try:
           qty = int(input("Qty to add: "))
       except ValueError:
           return
       existing["qty"] += qty
       save(db)
       print(f"  Restocked. New stock: {existing['qty']}")
       input("\nEnter to continue...")
       return
   try:
       qty   = int(input("Initial qty: ") or "0")
       cost  = float(input("Cost/unit: ") or "0")
       sell  = float(input("Sell/unit: ") or "0")
       alert = int(input("Low-stock alert at [5]: ") or "5")
   except ValueError:
       print("  Invalid input.")
       input("\nEnter to continue...")
       return
   db["items"][name] = {"qty": qty, "cost": cost, "sell": sell, "alert": alert}
   save(db)
   print(f"  Added '{name}'.")
   input("\nEnter to continue...")
#main code and gui
def main():
   db = load()
   while True:
       clear()
       txs_today = [t for t in db["transactions"] if t["date"] == today()]
       rev = sum(t["sell_price"] * t["qty"] for t in txs_today)
       profit = sum(t["profit"] for t in txs_today)
       margin = (profit / rev * 100) if rev > 0 else 0
       low = [n for n, i in db["items"].items() if 0 < i["qty"] <= i.get("alert", 5)]


       print("INVENTORY MANAGER")
       line()
       print(f"  Today  Revenue: {rp(rev)}  |  Profit: {rp(profit)}  |  Margin: {margin:.1f}%")
       print(f"  Items: {len(db['items'])} SKUs  |  Units in stock: {sum(i['qty'] for i in db['items'].values())}")
       if low:
           print(f"  LOW STOCK: {', '.join(low[:5])}{'...' if len(low) > 5 else ''}")
       line()
       print()
       print("  1. Sell / use item")
       print("  2. Storage list")
       print("  3. Today's sales log")
       print("  4. Add / restock item")
       print("  0. Exit")
       print()


       c = input("  Choice: ").strip()
       if   c == "1": sell(db)
       elif c == "2": show_stock(db)
       elif c == "3": show_log(db)
       elif c == "4": add_item(db)
       elif c == "0": print("\n  Bye!\n"); break


if __name__ == "__main__":
   main()
